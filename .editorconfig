# EditorConfig is awesome: https://EditorConfig.org
# Advanced Quantum AI System Configuration

# top-most EditorConfig file
root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

# TypeScript and JavaScript files
[*.{ts,tsx,js,jsx}]
indent_size = 2
max_line_length = 100
quote_type = single

# JSON files
[*.json]
indent_size = 2
max_line_length = 120

# Package.json files
[package*.json]
indent_size = 2
max_line_length = 120

# YAML files
[*.{yml,yaml}]
indent_size = 2
max_line_length = 120

# CSS, SCSS, and LESS files
[*.{css,scss,sass,less}]
indent_size = 2
max_line_length = 100

# HTML files
[*.{html,htm}]
indent_size = 2
max_line_length = 120

# Vue files
[*.vue]
indent_size = 2
max_line_length = 100

# React files
[*.{jsx,tsx}]
indent_size = 2
max_line_length = 100

# Markdown files
[*.{md,mdx}]
indent_size = 2
max_line_length = 120
trim_trailing_whitespace = false

# Configuration files
[*.{toml,ini,cfg,conf}]
indent_size = 2

# Docker files
[{Dockerfile*,*.dockerfile}]
indent_size = 4
max_line_length = 120

# Shell scripts
[*.{sh,bash,zsh}]
indent_size = 2
max_line_length = 120

# Batch files
[*.{bat,cmd}]
indent_size = 4
end_of_line = crlf

# PowerShell files
[*.{ps1,psm1,psd1}]
indent_size = 4
max_line_length = 120

# Python files
[*.py]
indent_size = 4
max_line_length = 88

# Go files
[*.go]
indent_style = tab
indent_size = 4
max_line_length = 120

# Rust files
[*.rs]
indent_size = 4
max_line_length = 100

# C/C++ files
[*.{c,cpp,cc,cxx,h,hpp,hxx}]
indent_size = 4
max_line_length = 100

# Java files
[*.java]
indent_size = 4
max_line_length = 120

# C# files
[*.cs]
indent_size = 4
max_line_length = 120

# PHP files
[*.php]
indent_size = 4
max_line_length = 120

# Ruby files
[*.rb]
indent_size = 2
max_line_length = 120

# Perl files
[*.pl]
indent_size = 4
max_line_length = 120

# SQL files
[*.sql]
indent_size = 2
max_line_length = 120

# XML files
[*.{xml,xsl,xslt,xsd,wsdl}]
indent_size = 2
max_line_length = 120

# GraphQL files
[*.{graphql,gql}]
indent_size = 2
max_line_length = 100

# Protocol Buffer files
[*.proto]
indent_size = 2
max_line_length = 100

# Terraform files
[*.{tf,tfvars}]
indent_size = 2
max_line_length = 120

# Kubernetes YAML files
[k8s*.{yml,yaml}]
indent_size = 2
max_line_length = 120

# Docker Compose files
[docker-compose*.{yml,yaml}]
indent_size = 2
max_line_length = 120

# GitHub Actions files
[.github/workflows/*.{yml,yaml}]
indent_size = 2
max_line_length = 120

# ESLint and Prettier config files
[.{eslintrc,prettierrc}*]
indent_size = 2
max_line_length = 120

# Babel config files
[babel.config.*]
indent_size = 2
max_line_length = 120

# Webpack config files
[webpack*.js]
indent_size = 2
max_line_length = 120

# Vite config files
[vite*.{js,ts}]
indent_size = 2
max_line_length = 120

# Rollup config files
[rollup*.{js,ts}]
indent_size = 2
max_line_length = 120

# Jest config files
[jest*.{js,ts}]
indent_size = 2
max_line_length = 120

# Cypress config files
[cypress*.{js,ts}]
indent_size = 2
max_line_length = 120

# Tailwind config files
[tailwind*.{js,ts}]
indent_size = 2
max_line_length = 120

# PostCSS config files
[postcss*.{js,ts}]
indent_size = 2
max_line_length = 120

# TypeScript config files
[tsconfig*.json]
indent_size = 2
max_line_length = 120

# Environment files
[.env*]
indent_size = 2
max_line_length = 120

# Git files
[.git*]
indent_size = 2
max_line_length = 120

# License files
[LICENSE*]
indent_size = 2
max_line_length = 120

# Changelog files
[CHANGELOG*]
indent_size = 2
max_line_length = 120

# README files
[README*]
indent_size = 2
max_line_length = 120
trim_trailing_whitespace = false

# Contributing files
[CONTRIBUTING*]
indent_size = 2
max_line_length = 120
trim_trailing_whitespace = false

# Security files
[SECURITY*]
indent_size = 2
max_line_length = 120
trim_trailing_whitespace = false

# Code of Conduct files
[CODE_OF_CONDUCT*]
indent_size = 2
max_line_length = 120
trim_trailing_whitespace = false

# Quantum-specific files
[*.quantum.*]
indent_size = 2
max_line_length = 100

# AI/ML specific files
[*.{ai,ml,neural}.*]
indent_size = 2
max_line_length = 100

# Cryptography specific files
[*.{crypto,cipher,hash}.*]
indent_size = 2
max_line_length = 100

# Monitoring and observability files
[*.{metrics,traces,logs}.*]
indent_size = 2
max_line_length = 120

# Security analysis files
[*.{security,audit,vulnerability}.*]
indent_size = 2
max_line_length = 120

# Performance analysis files
[*.{perf,benchmark,profile}.*]
indent_size = 2
max_line_length = 120

# Documentation files
[*.{doc,docs,documentation}.*]
indent_size = 2
max_line_length = 120
trim_trailing_whitespace = false

# Test files
[*.{test,spec,e2e,integration}.*]
indent_size = 2
max_line_length = 120

# Mock files
[*.{mock,stub,fake}.*]
indent_size = 2
max_line_length = 120

# Fixture files
[*.{fixture,fixtures}.*]
indent_size = 2
max_line_length = 120

# Snapshot files
[*.{snap,snapshot}.*]
indent_size = 2
max_line_length = 120
trim_trailing_whitespace = false

# Log files
[*.{log,logs}]
insert_final_newline = false
trim_trailing_whitespace = false

# Binary files
[*.{png,jpg,jpeg,gif,ico,svg,woff,woff2,ttf,eot,pdf,zip,tar,gz,bz2,xz,7z}]
insert_final_newline = false
trim_trailing_whitespace = false

# Temporary files
[*.{tmp,temp,cache,bak,backup,swp,swo}]
insert_final_newline = false
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# TypeScript and JavaScript files
[*.{ts,tsx,js,jsx}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# CSS and SCSS files
[*.{css,scss}]
indent_style = space
indent_size = 2

# HTML files
[*.html]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2