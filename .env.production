# ==============================================
# QUANTUM AI SYSTEM - PRODUCTION ENVIRONMENT
# ==============================================

# Server Configuration
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://your-domain.com
API_VERSION=v1

# Security Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-here-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_KEY=your-32-character-encryption-key
SALT_ROUNDS=12

# Database Configuration
MONGODB_URI=mongodb://mongo:27017/quantum-ai
MONGO_ROOT_USERNAME=quantum_admin
MONGO_ROOT_PASSWORD=secure_mongo_password_2024
DB_NAME=quantum-ai
DB_MAX_CONNECTIONS=100
DB_TIMEOUT=30000

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secure_redis_password_2024
REDIS_DB=0
REDIS_TTL=3600

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=30000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@quantum-ai.com
FROM_NAME=Quantum AI System

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain
UPLOAD_DEST=./uploads

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/quantum-ai.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
LOG_DATE_PATTERN=YYYY-MM-DD

# Monitoring Configuration
GRAFANA_USER=admin
GRAFANA_PASSWORD=secure_grafana_password_2024
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ElasticSearch Configuration
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=quantum-ai-logs
KIBANA_PORT=5601

# SSL Configuration
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem
SSL_CA_PATH=./ssl/ca.pem
ENABLE_HTTPS=true

# CORS Configuration
CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Session Configuration
SESSION_SECRET=your-session-secret-key-here
SESSION_MAX_AGE=86400000
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_KEYS=10000
CACHE_CHECK_PERIOD=600

# Quantum Simulation Configuration
QUANTUM_MAX_QUBITS=10
QUANTUM_MAX_GATES=1000
QUANTUM_TIMEOUT=60000
QUANTUM_CACHE_TTL=1800

# AI Processing Configuration
AI_MAX_CONTEXT_LENGTH=4000
AI_MAX_RESPONSE_LENGTH=2000
AI_TIMEOUT=30000
AI_RETRY_ATTEMPTS=3
AI_RETRY_DELAY=1000

# Performance Configuration
CLUSTER_WORKERS=0
MAX_MEMORY_USAGE=512
GC_INTERVAL=300000
HEALTH_CHECK_INTERVAL=30000

# Security Headers
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self' 'unsafe-inline'
CSP_STYLE_SRC='self' 'unsafe-inline'
CSP_IMG_SRC='self' data: https:
CSP_CONNECT_SRC='self' https://api.openai.com

# API Documentation
SWAGGER_TITLE=Quantum AI System API
SWAGGER_DESCRIPTION=Production-ready API for Quantum AI System with Max Planck methodology
SWAGGER_VERSION=1.0.0
SWAGGER_CONTACT_NAME=Quantum AI Team
SWAGGER_CONTACT_EMAIL=support@quantum-ai.com

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=quantum-ai-backups
BACKUP_S3_REGION=us-east-1

# Analytics Configuration
ANALYTICS_ENABLED=true
ANALYTICS_BATCH_SIZE=100
ANALYTICS_FLUSH_INTERVAL=60000

# Feature Flags
FEATURE_QUANTUM_SIMULATION=true
FEATURE_AI_CHAT=true
FEATURE_FILE_UPLOAD=true
FEATURE_REAL_TIME_UPDATES=true
FEATURE_ADVANCED_ANALYTICS=true

# Third-party Integrations
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
SENTRY_DSN=your-sentry-dsn-here
SLACK_WEBHOOK_URL=your-slack-webhook-url

# Development/Debug (set to false in production)
DEBUG=false
VERBOSE_LOGGING=false
ENABLE_PLAYGROUND=false
ENABLE_PROFILING=false

# ==============================================
# IMPORTANT SECURITY NOTES:
# 1. Change all default passwords and secrets
# 2. Use strong, unique passwords (min 16 chars)
# 3. Enable HTTPS in production
# 4. Regularly rotate secrets and keys
# 5. Monitor access logs and failed attempts
# 6. Keep this file secure and never commit to git
# ==============================================