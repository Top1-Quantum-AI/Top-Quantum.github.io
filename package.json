{
  "name": "unified-security-system",
  "version": "1.0.0",
  "type": "module",
  "description": "نظام الأمان الموحد - تطبيق ويب متقدم لمراقبة الأمان السيبراني باستخدام React و TypeScript",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "vite",
    "server": "node server/index.js",
    "dev:server": "nodemon server/index.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "postinstall": "echo 'Post-install setup complete'",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "build:server": "node -e \"const fs=require('fs');fs.cpSync('server','server-dist',{recursive:true})\"",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "security:check": "npm audit --audit-level moderate",
    "clean": "rm -rf dist node_modules/.vite"
  },
  "dependencies": {
    "@types/react-router-dom": "^5.3.3",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.1.5",
    "framer-motion": "^12.36.0",
    "helmet": "^7.1.0",
    "html2canvas": "^1.4.1",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.0",
    "localforage": "^1.10.0",
    "lucide-react": "^0.263.1",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "openai": "^5.12.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.2",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-import-resolver-typescript": "3.6.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-security": "^1.7.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.27",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.3.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.0.2",
    "vite": "^6.4.2"
  },
  "overrides": {
    "eslint-import-resolver-typescript": "3.6.3",
    "minimatch": ">=9.0.5"
  },
  "keywords": [
    "quantum",
    "computing",
    "planck",
    "physics",
    "simulation",
    "arabic"
  ],
  "author": "Quantum Revolution Team",
  "license": "MIT"
}
