{
  "name": "quantum-ai-microservices",
  "version": "2.0.0",
  "description": "Advanced Hybrid Quantum AI System - Microservices Architecture",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:*\"",
    "dev:gateway": "cd services/api-gateway && npm run dev",
    "dev:quantum-core": "cd services/quantum-core && npm run dev",
    "dev:ai-agents": "cd services/ai-agents && npm run dev",
    "dev:security": "cd services/security && npm run dev",
    "dev:dashboard": "cd apps/quantum-dashboard && npm run dev",
    "dev:lab": "cd apps/quantum-lab && npm run dev",
    "build": "npm run build:packages && npm run build:services && npm run build:apps",
    "build:packages": "lerna run build --scope=@quantum/*",
    "build:services": "lerna run build --scope=@quantum/service-*",
    "build:apps": "lerna run build --scope=@quantum/app-*",
    "test": "jest --projects jest.config.js",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:quantum": "jest --selectProjects quantum",
    "test:security": "jest --selectProjects security",
    "test:ai": "jest --selectProjects ai",
    "test:e2e": "playwright test",
    "test:load": "k6 run tests/load/quantum-load-test.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "security:audit": "npm audit --audit-level=moderate",
    "security:snyk": "snyk test",
    "security:owasp": "dependency-check --project quantum-ai --scan .",
    "docker:build": "docker-compose -f docker-compose.quantum.yml build",
    "docker:up": "docker-compose -f docker-compose.quantum.yml up -d",
    "docker:down": "docker-compose -f docker-compose.quantum.yml down",
    "docker:logs": "docker-compose -f docker-compose.quantum.yml logs -f",
    "k8s:deploy": "kubectl apply -f k8s-deployment.yaml",
    "k8s:monitoring": "kubectl apply -f k8s-monitoring.yaml",
    "k8s:delete": "kubectl delete -f k8s-deployment.yaml",
    "bootstrap": "lerna bootstrap",
    "clean": "lerna clean && rimraf node_modules",
    "reset": "npm run clean && npm install && npm run bootstrap",
    "release": "semantic-release",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "docs:build": "typedoc --out docs src",
    "docs:serve": "http-server docs -p 8080",
    "quantum:simulate": "node scripts/quantum-simulator.js",
    "quantum:benchmark": "node scripts/quantum-benchmark.js",
    "monitoring:start": "docker-compose -f docker-compose.monitoring.yml up -d",
    "monitoring:stop": "docker-compose -f docker-compose.monitoring.yml down",
    "pre-commit": "lint-staged",
    "prepare": "husky install",
    "postinstall": "npm run bootstrap"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/websockets": "^10.3.0",
