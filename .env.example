# This is an example of how to set up your environment variables

# Database connection details
DATABASE_URL=""
MONGODB_URL="mongodb://localhost:27017/quantum-ai"

# API keys
API_KEY=""
VITE_OPENAI_API_KEY=""
IBM_QUANTUM_TOKEN=""
BRAKET_ACCESS_KEY=""
BRAKET_SECRET_KEY=""

# Admin: first user with role='admin' in MongoDB — no hardcoded credentials
# Use: node -e "require('./server/models/User.js')" to promote a user to admin

# JWT & Security
JWT_SECRET=""
QUANTUM_ENCRYPTION_KEY=""

# Redis
REDIS_URL="redis://localhost:6379"

# Other secret keys or tokens
SECRET_KEY=""

# Frontend API URL (for Vite)
VITE_API_URL="/api"