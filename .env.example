# Environment Variables Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control for security

# OpenAI API Configuration
VITE_OPENAI_API_KEY=your-openai-api-key-here

# Master Secret Code for the system
# Generate a strong, unique secret for production
# Use a secure random generator, minimum 32 characters
MASTER_SECRET_CODE=your-secure-master-secret-here

# Server Configuration
PORT=3000

# API Configuration
API_BASE_URL=http://localhost:3001
API_TIMEOUT=5000

# Security Settings
SECURITY_LEVEL=high
ENABLE_LOGGING=true

# Database Configuration (if needed)
# DATABASE_URL=your-database-connection-string

# SECURITY NOTES:
# 1. Never use default or example values in production
# 2. Use environment-specific configurations
# 3. Regularly rotate secrets and API keys
# 4. Use strong, randomly generated passwords